#include? "Version.xcconfig"

TEAM_ID=

PRODUCT_NAME=Tuvora
PRODUCT_BUNDLE_IDENTIFIER=com.nuvio.app.Nuvio$(TEAM_ID)

// ComposeApp uses BundledSQLiteDriver — SQLite is compiled into the Kotlin framework, so the
// app must NOT also link the system libsqlite3 (that would duplicate every sqlite3_* symbol).
// The old sqlite3_load_extension_stub.c is removed too — bundled SQLite exports the real one.
OTHER_LDFLAGS=$(inherited)