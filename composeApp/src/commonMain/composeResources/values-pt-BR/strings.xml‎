    <string name="settings_licenses_attributions_tmdb_title">The Movie Database (TMDB)</string>
    <string name="settings_licenses_attributions_tmdb_body">O Nuvio usa a API do TMDB para metadados de filmes e séries, artes, trailers, elenco, detalhes de produção, coleções e recomendações. Este produto usa a API do TMDB, mas não é endossado ou certificado pelo TMDB.</string>
